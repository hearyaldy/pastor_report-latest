rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && (
        currentUserData().isAdmin == true ||
        currentUserData().userRole in ['admin', 'superAdmin'] ||
        currentUserData().role in ['admin', 'superAdmin', 'Admin', 'Super Admin']
      );
    }

    // Helper function to check if user is mission admin
    function isMissionAdmin() {
      return isAuthenticated() &&
             (currentUserData().userRole == 'missionAdmin' ||
              currentUserData().role in ['missionAdmin', 'Mission Admin']);
    }

    // Helper function to check if user is a Mission President
    function isMissionPresident() {
      return isAuthenticated() &&
             (currentUserData().role == 'Mission President' ||
              currentUserData().userRole == 'missionPresident');
    }

    // Helper function to check if user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user belongs to a specific mission
    function isMissionMember(missionName) {
      return isAuthenticated() &&
             currentUserData().mission == missionName;
    }
    
    // Helper function to check if user is a Ministerial Secretary
    function isMinisterialSecretary() {
      return isAuthenticated() &&
             (currentUserData().userRole == 'ministerialSecretary' ||
              currentUserData().role in ['ministerialSecretary', 'Ministerial Secretary']);
    }
    
    // Helper function to check if user is an Officer
    function isOfficer() {
      return isAuthenticated() &&
             (currentUserData().userRole == 'officer' ||
              currentUserData().role in ['officer', 'Officer']);
    }
    
    // Helper function to check if user is a Director
    function isDirector() {
      return isAuthenticated() &&
             (currentUserData().userRole == 'director' ||
              currentUserData().role in ['director', 'Director']);
    }
    
    // Helper function to check if user is a Super Admin
    function isSuperAdmin() {
      return isAuthenticated() &&
             (currentUserData().userRole == 'superAdmin' ||
              currentUserData().role in ['superAdmin', 'Super Admin']);
    }

    // Helper function to check if user is a District Pastor
    function isDistrictPastor() {
      return isAuthenticated() &&
             (currentUserData().role == 'District Pastor' ||
              currentUserData().userRole == 'districtPastor');
    }

    // Helper function to check if user is a Church Treasurer
    function isChurchTreasurer() {
      return isAuthenticated() &&
             (currentUserData().role == 'Church Treasurer' ||
              currentUserData().userRole == 'churchTreasurer');
    }

    // Helper functions to get current user's district and mission IDs
    function userDistrictId() {
      return isAuthenticated()
        ? currentUserData().district
        : null;
    }

    function userMissionId() {
      return isAuthenticated()
        ? currentUserData().mission
        : null;
    }

    function userChurchId() {
      return isAuthenticated()
        ? currentUserData().churchId
        : null;
    }

    function isMissionLevelReporter() {
      return isMinisterialSecretary() || isOfficer() || isDirector();
    }

    function isMissionScopedAdmin(missionId) {
      return isAdmin() ||
        (isMissionAdmin() && missionId == userMissionId());
    }

    function isUserMissionValue(missionValue) {
      return missionValue == userMissionId() ||
        (exists(/databases/$(database)/documents/missions/$(userMissionId())) &&
          get(/databases/$(database)/documents/missions/$(userMissionId())).data.name == missionValue);
    }

    function canManageMissionValue(missionValue) {
      return isAdmin() ||
        (isMissionAdmin() && isUserMissionValue(missionValue));
    }

    function isDistrictScopedPastor(districtId) {
      return isDistrictPastor() && districtId == userDistrictId();
    }

    function hasNoProtectedUserChanges() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny([
          'isAdmin',
          'isMissionAdmin',
          'isEditor',
          'isPremium',
          'userRole',
          'role'
        ]);
    }

    function hasSafeInitialUserRole() {
      return
        (!request.resource.data.keys().hasAny(['isAdmin']) ||
          request.resource.data.isAdmin == false) &&
        (!request.resource.data.keys().hasAny(['isMissionAdmin']) ||
          request.resource.data.isMissionAdmin == false) &&
        (!request.resource.data.keys().hasAny(['isEditor']) ||
          request.resource.data.isEditor == false) &&
        (!request.resource.data.keys().hasAny(['isPremium']) ||
          request.resource.data.isPremium == false) &&
        (!request.resource.data.keys().hasAny(['userRole']) ||
          request.resource.data.userRole == 'user') &&
        (!request.resource.data.keys().hasAny(['role']) ||
          request.resource.data.role in ['user', 'User']);
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile. Privileged users can read user
      // records for management/reporting views.
      allow get: if isOwner(userId) ||
                    isAdmin() ||
                    isMissionAdmin() ||
                    isMissionLevelReporter();

      // User list/search exposes emails and assignments, so keep it to
      // privileged management/reporting roles.
      allow list: if isAuthenticated() &&
                    (isAdmin() || isMissionAdmin() || isMissionLevelReporter());

      // Users can create their own document during registration, but cannot
      // bootstrap privileged roles or admin flags from a modified client.
      allow create: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      hasSafeInitialUserRole();

      // Users can update their own non-privileged profile fields.
      allow update: if isOwner(userId) &&
                       hasNoProtectedUserChanges();

      // Only admins can update any user's isAdmin field
      allow update: if isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // Departments collection (legacy structure)
    match /departments/{departmentId} {
      // Anyone can read departments
      allow read: if true;

      // Only admins can create, update, or delete departments
      allow create, update, delete: if isAdmin();
    }
    
    // Missions collection (new mission-based structure)
    match /missions/{missionId} {
      // Allow anyone to read mission details (needed for registration page)
      allow read: if true;
      
      // Only admins can create, update, or delete missions
      allow create, update, delete: if isAdmin();
      
      // Function to get mission name from document
      function getMissionName() {
        return get(/databases/$(database)/documents/missions/$(missionId)).data.name;
      }
      
      // Departments subcollection within missions
      match /departments/{departmentId} {
        // Anyone can read mission departments
        allow read: if true;

        // Only privileged roles can change department definitions and form URLs.
        allow create, update, delete: if isAdmin() || isMissionAdmin();
        
        // Future enhancement: Mission-specific reports
        match /reports/{reportId} {
          // Anyone in the mission can read their mission's reports
          allow read: if isMissionMember(getMissionName()) || isAdmin();
          
          // Only mission members and admins can create reports for their mission
          allow create: if isMissionMember(getMissionName()) || isAdmin();
          
          // Only report creators and admins can update or delete reports
          allow update, delete: if isAdmin() || 
                               (isAuthenticated() && request.auth.uid == resource.data.createdBy);
        }
      }
    }

    // App settings collection (for global app configuration)
    match /settings/{settingId} {
      // Anyone authenticated can read settings
      allow read: if isAuthenticated();

      // Only admins can modify settings
      allow create, update, delete: if isAdmin();
    }

    // Email domain allowlist — must be readable before account creation (unauthenticated)
    match /settings/emailDomains {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Staff collection (centralized staff directory)
    match /staff/{staffId} {
      // Users can see staff/workers in their own mission. Admins can see all.
      allow read: if isAuthenticated() &&
                    (isAdmin() || isUserMissionValue(resource.data.mission));

      // Only administrators can manage staff records.
      allow create: if isAuthenticated() &&
                      canManageMissionValue(request.resource.data.mission);

      allow update: if isAuthenticated() &&
                      canManageMissionValue(resource.data.mission) &&
                      canManageMissionValue(request.resource.data.mission);

      allow delete: if isAuthenticated() &&
                      canManageMissionValue(resource.data.mission);
    }

    // Regions collection (organizational structure)
    match /regions/{regionId} {
      // Allow anyone to read regions (needed for registration and onboarding)
      allow read: if true;

      // Only admins and mission admins can manage organizational regions.
      allow create: if isAuthenticated() &&
                       isMissionScopedAdmin(request.resource.data.missionId);

      // Keep region ownership inside the caller's authorized mission.
      allow update: if isAuthenticated() &&
                       isMissionScopedAdmin(resource.data.missionId) &&
                       request.resource.data.missionId == resource.data.missionId;

      allow delete: if isMissionScopedAdmin(resource.data.missionId);
    }

    // Districts collection (organizational structure)
    match /districts/{districtId} {
      // Allow anyone to read districts (needed for registration and onboarding)
      // District pastors can read their own district
      allow read: if true || (isDistrictPastor() && resource.data.id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.district);

      // Only admins and mission admins can manage organizational districts.
      allow create: if isAuthenticated() &&
                       isMissionScopedAdmin(request.resource.data.missionId);

      // Keep district ownership inside the caller's authorized mission.
      allow update: if isAuthenticated() &&
                       isMissionScopedAdmin(resource.data.missionId) &&
                       request.resource.data.missionId == resource.data.missionId;

      allow delete: if isMissionScopedAdmin(resource.data.missionId);
    }

    // Churches collection
    match /churches/{churchId} {
      // Allow authenticated users to read churches (needed for listings and assignments)
      allow read: if isAuthenticated();

      // Churches can be created by admins/mission admins in scope, or by a
      // district pastor only inside their assigned district.
      allow create: if isAuthenticated() && (
        isMissionScopedAdmin(request.resource.data.missionId) ||
        isDistrictScopedPastor(request.resource.data.districtId)
      );

      // Keep church reassignment inside authorized scope. District pastors
      // cannot move churches out of their own district.
      allow update: if isAuthenticated() && (
        (isMissionScopedAdmin(resource.data.missionId) &&
          request.resource.data.missionId == resource.data.missionId) ||
        (isDistrictScopedPastor(resource.data.districtId) &&
          request.resource.data.districtId == resource.data.districtId)
      );

      allow delete: if isMissionScopedAdmin(resource.data.missionId);
    }

    // Financial Reports collection
    match /financial_reports/{reportId} {
      // Allow reads for admins, mission admins, district pastors (their district/mission), church treasurers (their church), or the report submitter
      allow read: if isAuthenticated() &&
                     (isAdmin() ||
                      (isMissionAdmin() && resource.data.missionId == userMissionId()) ||
                      (isMissionPresident() && resource.data.missionId == userMissionId()) ||
                      (isDistrictPastor() && resource.data.districtId == userDistrictId()) ||
                      (isChurchTreasurer() && resource.data.churchId == userChurchId()) ||
                      resource.data.submittedBy == request.auth.uid);
      // Allow creates for allowed roles within their scope
      allow create: if isAuthenticated() && (
        isAdmin() ||
        (isMissionAdmin() && request.resource.data.missionId == userMissionId()) ||
        (isDistrictPastor() && request.resource.data.districtId == userDistrictId()) ||
        (isChurchTreasurer() && request.resource.data.churchId == userChurchId())
      ) && request.resource.data.submittedBy == request.auth.uid;

      // Allow updates for report owner, admins, mission admins, district pastors (their district/mission), and treasurers (their church)
      allow update: if isAuthenticated() && (
        resource.data.submittedBy == request.auth.uid ||
        isAdmin() ||
        (isMissionAdmin() &&
          resource.data.missionId == userMissionId() &&
          request.resource.data.missionId == userMissionId()) ||
        (isDistrictPastor() &&
          resource.data.districtId == userDistrictId() &&
          request.resource.data.districtId == userDistrictId()) ||
        (isChurchTreasurer() &&
          resource.data.churchId == userChurchId() &&
          request.resource.data.churchId == userChurchId())
      ) && request.resource.data.submittedBy == resource.data.submittedBy;

      // Only admins can delete financial reports
      allow delete: if isAdmin();
    }

    // Borang B Reports (Monthly Ministerial Reports)
    match /borang_b_reports/{reportId} {
      // Allow list/get operations for different user types
      // - Superadmin/Admin, MinisterialSecretary, Officer, and Director can read all reports (list and get)
      // - Mission Admins can read reports for their own mission only
      // - Regular users can list/get their own reports (with userId query filter)
      
      // List permission - allows querying the collection
      // Regular users can list if they query with userId filter
      // Admins/Mission-level staff can list all without filter
      allow list: if isAuthenticated() && (
                    resource.data.userId == request.auth.uid ||
                    isAdmin() ||
                    isSuperAdmin() ||
                    (isMissionLevelReporter() && resource.data.missionId == userMissionId()) ||
                    (isMissionAdmin() && resource.data.missionId == userMissionId())
                  );
      
      // Get permission - allows reading individual documents
      allow get: if isAuthenticated() && (
                    resource.data.userId == request.auth.uid ||
                    isAdmin() ||
                    isSuperAdmin() ||
                    (isMissionLevelReporter() && resource.data.missionId == userMissionId()) ||
                    (isMissionAdmin() && resource.data.missionId == userMissionId())
                  );

      // Authenticated users can create their own reports
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Users can update their own reports
      // Superadmin, MinisterialSecretary, Officer, and Director can update any report
      allow update: if isAuthenticated() &&
                      (resource.data.userId == request.auth.uid ||
                       isSuperAdmin() ||
                       (isMissionLevelReporter() && resource.data.missionId == userMissionId())) &&
                      request.resource.data.userId == resource.data.userId;

      // Users can delete their own reports
      // Superadmin, Admin, MinisterialSecretary, Officer, and Director can delete any reports
      allow delete: if isAuthenticated() &&
                      (resource.data.userId == request.auth.uid ||
                       isSuperAdmin() ||
                       isAdmin() ||
                       (isMissionLevelReporter() && resource.data.missionId == userMissionId()));
    }

    // Admin Activity feed (used by Admin Dashboard Recent Activity)
    match /admin_activity/{activityId} {
      // Allow admins, mission admins, and district pastors to read recent activity
      allow read: if isAdmin() || isMissionAdmin() || isDistrictPastor();

      // Writes should be restricted; allow only admins to create/update/delete
      // Optionally, you can further restrict to Cloud Functions by checking request.auth.token.firebase.sign_in_provider
      allow create, update, delete: if isAdmin();
    }

    // ===== Personal Data Collections (User-scoped) =====
    
    // Activities collection - pastor's daily activities
    match /activities/{activityId} {
      // Users can read their own activities (list queries and individual docs)
      allow read: if isAuthenticated() && 
                    (resource == null || resource.data.userId == request.auth.uid);
      
      // Users can only create their own activities
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid;
      
      // Users can only update their own activities
      // Allow update if: existing userId matches AND (new userId matches OR userId not in update)
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      (!request.resource.data.keys().hasAny(['userId']) || 
                       request.resource.data.userId == request.auth.uid);
      
      // Users can only delete their own activities
      allow delete: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid;
    }

    // Todos collection - personal todo list
    match /todos/{todoId} {
      // Users can read their own todos (list queries and individual docs)
      allow read: if isAuthenticated() &&
                    (resource == null || resource.data.userId == request.auth.uid);

      // Users can only create their own todos
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Users can only update their own todos
      // Allow update if: existing userId matches AND (new userId matches OR userId not in update)
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid &&
                      (!request.resource.data.keys().hasAny(['userId']) ||
                       request.resource.data.userId == request.auth.uid);

      // Users can only delete their own todos
      allow delete: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }

    // Appointments collection - personal appointments
    match /appointments/{appointmentId} {
      // Users can read their own appointments (list queries and individual docs)
      allow read: if isAuthenticated() && 
                    (resource == null || resource.data.userId == request.auth.uid);
      
      // Users can only create their own appointments
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid;
      
      // Users can only update their own appointments
      // Allow update if: existing userId matches AND (new userId matches OR userId not in update)
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      (!request.resource.data.keys().hasAny(['userId']) || 
                       request.resource.data.userId == request.auth.uid);
      
      // Users can only delete their own appointments
      allow delete: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid;
    }

    // Global Events collection - read-only for all authenticated users, write for admins
    match /global_events/{eventId} {
      // All authenticated users can read global events
      allow read: if isAuthenticated();
      
      // Only admins and super admins can create/update/delete global events
      allow create, update, delete: if isAdmin() || isSuperAdmin();
    }

    // Personal Events collection - user-scoped personal events
    match /events/{eventId} {
      // Users can read their own events (list queries and individual docs)
      allow read: if isAuthenticated() && 
                    (resource == null || resource.data.userId == request.auth.uid);
      
      // Users can only create their own events
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid;
      
      // Users can only update their own events
      // Allow update if: existing userId matches AND (new userId matches OR userId not in update)
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      (!request.resource.data.keys().hasAny(['userId']) || 
                       request.resource.data.userId == request.auth.uid);
      
      // Users can only delete their own events
      allow delete: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid;
    }
    
    // Resources collection - mission-specific resources
    match /resources/{resourceId} {
      // Allow mission members and admins to read resources from their mission.
      allow read: if isAuthenticated() &&
                    (isAdmin() ||
                     resource.data.missionId == userMissionId());
      
      // Allow mission members and scoped admins to create resources only for
      // their own mission, attributed to themselves.
      allow create: if isAuthenticated() &&
                      (isAdmin() ||
                       request.resource.data.missionId == userMissionId()) &&
                       request.resource.data.userId == request.auth.uid;
      
      // Allow resource creators and scoped admins to update resources without
      // moving them between missions or reassigning ownership.
      allow update: if isAuthenticated() &&
                      (isAdmin() ||
                       (resource.data.missionId == userMissionId() &&
                        resource.data.userId == request.auth.uid) ||
                       isMissionScopedAdmin(resource.data.missionId)) &&
                      request.resource.data.missionId == resource.data.missionId &&
                      request.resource.data.userId == resource.data.userId;
      
      // Allow resource creators and scoped admins to delete resources.
      allow delete: if isAuthenticated() &&
                      (isAdmin() ||
                       (resource.data.missionId == userMissionId() &&
                        resource.data.userId == request.auth.uid) ||
                       isMissionScopedAdmin(resource.data.missionId));
    }

    // Location requests — users request regions/districts during onboarding
    match /locationRequests/{requestId} {
      // Any authenticated user can create a request for their own mission
      allow create: if isAuthenticated() &&
                       request.resource.data.requestedBy == request.auth.uid;
      // Any authenticated user can read requests (for the admin panel stream)
      allow read: if isAuthenticated();
      // Only admins can approve or reject (update status)
      allow update, delete: if isAdmin() || isMissionAdmin();
    }
  }
}
